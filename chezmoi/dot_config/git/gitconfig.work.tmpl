# vim: set filetype=ini
[user]
  name = Colin Seymour
  email = colin@github.com
  {{- if glob (printf "%s/.ssh/git_signing_ed25519.pub" .chezmoi.homeDir) }}
  signingkey = {{ printf "%s/.ssh/git_signing_ed25519.pub" .chezmoi.homeDir }}
  {{- else }}
  # ID taken from `gpg --list-secret-keys --keyid-format LONG` - more accurate than using emails.
