{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "lsp": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "question": "allow"
  },
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {file:~/.config/opencode/secrets/github-pat}"
      }
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }{{- if eq .install_type "home" }},
    "homeassistant": {
      "type": "remote",
      "url": "http://ha.local:8123/api/mcp",
      "enabled": true,
      "oauth": true
    }
    {{- end }}
  }
}
